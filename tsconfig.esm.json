{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "rootDir": "src",
    "outDir": "dist/esm",
    "removeComments": false
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", ".test-build", "**/*.spec.ts", "**/*.test.ts"]
}
